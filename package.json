{
  "name": "geoserver-viewer",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "concurrently -k -n \"server,client\" -c \"yellow,cyan\" \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "pnpm -F server dev",
    "build:server": "pnpm -F server build",
    "start:server": "pnpm -F server start",
    "type-check:server": "pnpm -F server type-check",
    "lint:server": "pnpm -F server lint",
    "lint-fix:server": "pnpm -F server lint-fix",
    "format:server": "pnpm -F server format",
    "format-check:server": "pnpm -F server format-check",
    "test:server": "pnpm -F server test",
    "test:coverage:server": "pnpm -F server test:coverage",
    "dev:client": "pnpm -F client dev",
    "build:client": "pnpm -F client build",
    "preview:client": "pnpm -F client preview",
    "type-check:client": "pnpm -F client type-check",
    "lint:client": "pnpm -F client lint",
    "lint-fix:client": "pnpm -F client lint-fix",
    "format:client": "pnpm -F client format",
    "format-check:client": "pnpm -F client format-check",
    "test:client": "pnpm -F client test",
    "test:coverage:client": "pnpm -F client test:coverage",
    "copy-env": "node ./scripts/copy-env.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/uuid": "^11.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4"
  },
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "workspaces": [
    "client",
    "server"
  ],
  "dependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "uuid": "^9.0.1"
  }
}
